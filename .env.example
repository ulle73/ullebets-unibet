# Reuse the exact same Cosmos/Mongo connection string as C:/dev/frontend/ullebets-vecel.
# Do not commit .env.local.
MONGODB_URI="mongodb+srv://USER:PASSWORD@my-app-cluster.mongocluster.cosmos.azure.com/?tls=true&authMechanism=SCRAM-SHA-256&retrywrites=false&maxIdleTimeMS=120000"

# Target database for this repo. Must not be app.
MONGODB_DB=ullebets_unibet

# Source database from ullebets-vecel.
SOURCE_MONGODB_DB=app

# Safety limits for daily app sync and raw odds fetch.
MAX_MATCHES_PER_RUN=500
SNAPSHOT_IMPORT_LIMIT=200
MAX_ODDS_JOBS_PER_RUN=100
MAX_RAW_PAYLOAD_MB_PER_RUN=300
RAW_ODDS_TTL_DAYS=30
