# Reuse the exact same Cosmos/Mongo connection string as C:/dev/frontend/ullebets-vecel.
# Do not commit .env.local.
MONGODB_URI="mongodb+srv://USER:PASSWORD@my-app-cluster.mongocluster.cosmos.azure.com/?tls=true&authMechanism=SCRAM-SHA-256&retrywrites=false&maxIdleTimeMS=120000"
MONGODB_DB=ullebets_unibet

# Optional safety limits for MVP runs.
MAX_LEAGUES_PER_RUN=5
MAX_MATCHES_PER_RUN=50
MAX_ODDS_JOBS_PER_RUN=25
MAX_RAW_PAYLOAD_MB_PER_RUN=200
RAW_ODDS_TTL_DAYS=30

# Generic Unibet/Kambi endpoint templates.
# Keep them local until verified. The code replaces {league_slug}, {league_id}, {from}, {to}, {event_id}.
UNIBET_DISCOVERY_URL_TEMPLATE=""
UNIBET_EVENT_ODDS_URL_TEMPLATE=""
UNIBET_COOKIE=""
UNIBET_USER_AGENT="Mozilla/5.0"
